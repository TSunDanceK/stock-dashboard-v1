{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mystockharbour.com"
        }
      ],
      "destination": "https://mystockharbor.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.mystockharbour.com"
        }
      ],
      "destination": "https://mystockharbor.com/:path*",
      "permanent": true
    }
  ]
}
